﻿
@model HospitalProyect.ViewsModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <h1 class="mb-1">Bienvenido, @ViewBag.UserName</h1>
    <p class="text-muted mb-4">Resumen general del personal del sistema</p>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 border-start border-primary border-4 h-100">
                <div class="card-body">
                    <h5 class="text-primary fw-bold text-uppercase mb-1">Total Personal</h5>
                    <div class="h2 font-weight-bold text-dark">@Model.TotalStaff</div>
                </div>
            </div>
        </div>

        <div class="col-md-5 mb-4">
            <div class="card shadow-sm border-0 border-start border-success border-4 h-100">
                <div class="card-body">
                    <h5 class="text-success fw-bold text-uppercase mb-1">Activos</h5>
                    <div class="h2 font-weight-bold text-dark">@Model.ActiveStaff</div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 border-start border-danger border-4 h-100">
                <div class="card-body">
                    <h5 class="text-danger fw-bold text-uppercase mb-1">Inactivos</h5>
                    <div class="h2 font-weight-bold text-dark">@Model.InactiveStaff</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-3 mb-5">
        <div class="col-md-5 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 pt-4">
                    <h5 class="mb-0 fw-bold text-secondary">Personal por Categoría</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @if (Model.StaffByCategory.Count == 0)
                        {
                            <li class="list-group-item text-muted">No hay datos para mostrar.</li>
                        }
                        else
                        {
                            @foreach (var item in Model.StaffByCategory)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    @item.Key
                                    <span class="badge bg-primary rounded-pill">@item.Value</span>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-7 mb-4">
            <div class="card shadow-sm border-0 pt-4">
                <div class="card-header bg-white border-0 pt-4">
                    <h5 class="mb-0 fw-bold text-secondary">Distribución Visual</h5>
                </div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <canvas id="chartCategorias" style=" max-height: 200px;"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const categoriasLabels = @Html.Raw(Json.Serialize(Model.StaffByCategory.Keys));
        const categoriasDatos = @Html.Raw(Json.Serialize(Model.StaffByCategory.Values));

        const coloresBackground = [
            'rgba(54, 162, 235, 0.2)',
            'rgba(75, 192, 192, 0.2)',
            'rgba(255, 206, 86, 0.2)',
            'rgba(255, 99, 132, 0.2)',
            'rgba(153, 102, 255, 0.2)',
            'rgba(255, 159, 64, 0.2)'
        ]

        const ctx = document.getElementById('chartCategorias').getContext('2d');

        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: categoriasLabels,
                datasets: [{
                    label: 'Cantidad de Personal',
                    data: categoriasDatos,
                    backgroundColor: coloresBackground,
                    borderColor: coloresBackground.map(color => color.replace('0.2', '1')),
                    borderWidth: 2,
                    hoverOffset: 10
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            padding: 20,
                            usePointStyle: true,
                        }
                    },
                    tooltip: {
                        padding:10,
                        cornerRadius: 5
                    }
                }
            }
        });
    </script>
}